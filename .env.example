# --- Required ---
TELEGRAM_BOT_TOKEN=123456789:AA...your-bot-token-from-BotFather
OPENAI_API_KEY=sk-...               # used for both Whisper transcription and grading

# --- Optional overrides ---
OPENAI_MODEL=gpt-5-mini             # grading + question generation; "gpt-5" = sharper, "gpt-5-nano" = cheaper
WHISPER_MODEL=whisper-1             # or gpt-4o-transcribe for higher-quality transcription

DEFAULT_TZ=Europe/London
DEFAULT_ACTIVE_START=9              # cards start at 09:00
DEFAULT_ACTIVE_END=21              # ...and stop at 21:00
DEFAULT_SUMMARY_HOUR=21            # daily recap goes out at 21:30
REVIEW_PACE=8                      # cards/day once all levels are cleared

DB_PATH=coach.db

# Levels (count, days, difficulty) are defined in config.py -> LEVELS. Edit there.
